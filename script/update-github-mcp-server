#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "open3"
require "pathname"

REPOSITORY = "github/github-mcp-server"
ARTIFACTS = %w[
  github-mcp-server_Darwin_arm64.tar.gz
  github-mcp-server_Darwin_x86_64.tar.gz
  github-mcp-server_Linux_arm64.tar.gz
  github-mcp-server_Linux_x86_64.tar.gz
].freeze

def capture!(*command)
  stdout, stderr, status = Open3.capture3(*command)
  abort stderr unless status.success?

  stdout
end

release = JSON.parse(capture!("gh", "release", "view", "--repo", REPOSITORY, "--json", "tagName"))
tag = release.fetch("tagName")
version = tag.delete_prefix("v")
abort "Unexpected release tag: #{tag}" unless version.match?(/\A\d+(?:\.\d+)+\z/)

manifest = capture!(
  "gh", "release", "download", tag,
  "--repo", REPOSITORY,
  "--pattern", "github-mcp-server_*_checksums.txt",
  "--output", "-",
)

checksums = {}
manifest.each_line do |line|
  match = line.match(/\A([0-9a-f]{64})\s+(\S+)\s*\z/)
  next unless match

  checksum, artifact = match.captures
  abort "Duplicate checksum for #{artifact}" if checksums.key?(artifact)

  checksums[artifact] = checksum
end

missing_artifacts = ARTIFACTS - checksums.keys
abort "Missing checksums for: #{missing_artifacts.join(", ")}" if missing_artifacts.any?

formula_path = Pathname(__dir__).parent/"Formula/github-mcp-server.rb"
contents = formula_path.read

version_pattern = /^  version "[^"]+"$/
abort "Expected exactly one version stanza" unless contents.scan(version_pattern).one?

contents.sub!(version_pattern, %(  version "#{version}"))

ARTIFACTS.each do |artifact|
  checksum_pattern = /^(\s+url "[^"\n]*\/#{Regexp.escape(artifact)}"\n)(\s+)sha256 "[0-9a-f]{64}"$/
  abort "Expected exactly one URL and checksum for #{artifact}" unless contents.scan(checksum_pattern).one?

  contents.sub!(checksum_pattern) do
    "#{Regexp.last_match(1)}#{Regexp.last_match(2)}sha256 \"#{checksums.fetch(artifact)}\""
  end
end

if formula_path.read == contents
  puts "github-mcp-server is already at #{version}"
else
  formula_path.write(contents)
  puts "Updated github-mcp-server to #{version}"
end
